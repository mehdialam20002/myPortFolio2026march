# ── AI assistant ───────────────────────────────────────────────────
# Choose the provider: "groq" (default) or "gemini"
AI_PROVIDER=groq

# Groq — free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — free key from https://aistudio.google.com/apikey  (only if AI_PROVIDER=gemini)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── Admin dashboard (Decap CMS) GitHub login ───────────────────────
# Create a GitHub OAuth App: https://github.com/settings/developers
#   Homepage URL:              https://mehdiiialam.netlify.app
#   Authorization callback URL: https://mehdiiialam.netlify.app/.netlify/functions/callback
OAUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
